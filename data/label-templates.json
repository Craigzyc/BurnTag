{
  "FreshControls": {
    "printer": "niimbot-b21-pro",
    "labelSize": "50x30",
    "orientation": "landscape",
    "header": {
      "text": "FreshControls",
      "fontSize": 40,
      "fontFamily": "Arial",
      "inverted": false,
      "separator": true
    },
    "lines": [
      {
        "template": "S/N: {serial}",
        "fontSize": 24,
        "bold": false
      },
      {
        "template": "MAC: {mac}",
        "fontSize": 22,
        "bold": false
      },
      {
        "template": "Contains:",
        "fontSize": 22,
        "bold": false
      },
      {
        "template": "FCC ID : Z4T-WIO-SX1262 ",
        "fontSize": 22,
        "bold": false
      },
      {
        "template": "FCC ID : Z4T-XIAOESP32S3 ",
        "fontSize": 22,
        "bold": false
      },
      {
        "template": "NODE ID: {config:id}",
        "fontSize": 22,
        "bold": false
      }
    ],
    "lineSpacing": 4,
    "qr": {
      "enabled": true,
      "size": 200,
      "position": "right",
      "urlTemplate": "https://app.freshcontrols.io/onboard?sn={serial}&mac={mac}",
      "errorCorrection": "M"
    },
    "footer": {
      "lines": [
        "Designed and Assembled in the USA",
        "Scan QR to onboard device"
      ],
      "fontSize": 18,
      "separatorLine": true
    }
  },
  "MeshNode": {
    "printer": "niimbot-b21-pro",
    "labelSize": "50x30",
    "orientation": "landscape",
    "header": {
      "text": "MeshNode",
      "fontSize": 40,
      "fontFamily": "Arial",
      "align": "center",
      "inverted": false,
      "separator": true
    },
    "lines": [
      {
        "template": "S/N: {serial}",
        "fontSize": 24,
        "bold": false
      },
      {
        "template": "MAC: {mac}",
        "fontSize": 22,
        "bold": false
      },
      {
        "template": "Contains:",
        "fontSize": 22,
        "bold": false
      },
      {
        "template": "FCC ID : Z4T-WIO-SX1262 ",
        "fontSize": 22,
        "bold": false
      },
      {
        "template": "FCC ID : Z4T-XIAOESP32S3 ",
        "fontSize": 22,
        "bold": false
      },
      {
        "template": "NODE ID: {config:id}",
        "fontSize": 22,
        "bold": false
      },
      {
        "template": "SiteID: {config:key}",
        "fontSize": 22,
        "bold": false
      }
    ],
    "lineSpacing": 4,
    "qr": {
      "enabled": false,
      "size": 200,
      "position": "right",
      "urlTemplate": "https://app.freshcontrols.io/onboard?sn={serial}&mac={mac}",
      "errorCorrection": "M"
    },
    "footer": {
      "lines": [
        "Designed and Assembled in the USA"
      ],
      "fontSize": 18,
      "align": "left",
      "separatorLine": true
    }
  }
}