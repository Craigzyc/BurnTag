{
  "name": "burntag",
  "version": "1.0.2",
  "description": "BurnTag — ESP32 Flash & Label Station",
  "private": true,
  "type": "module",
  "main": "main/index.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "rebuild": "electron-rebuild",
    "postinstall": "node scripts/patch-niimbotjs.js",
    "build": "electron-builder --win",
    "build:dir": "electron-builder --win --dir"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "build": {
    "appId": "com.burntag.burntag",
    "productName": "BurnTag",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main/**/*",
      "preload/**/*",
      "renderer/**/*",
      "node_modules/**/*",
      "!node_modules/**/test/**",
      "!node_modules/**/*.map"
    ],
    "win": {
      "target": "nsis",
      "icon": "BurnTagIcon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "installerIcon": "BurnTagIcon.ico",
      "uninstallerIcon": "BurnTagIcon.ico"
    },
    "extraResources": [
      {
        "from": "data",
        "to": "data",
        "filter": [
          "config.json"
        ]
      }
    ]
  },
  "devDependencies": {
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "electron-rebuild": "^3.2.9",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@mmote/niimblue-node": "github:MultiMote/niimblue-node",
    "@mmote/niimbluelib": "^0.0.1-alpha.38",
    "esptool-js": "^0.6.0",
    "niimbotjs": "^0.3.2",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "qrcode": "^1.5.4",
    "serialport": "^13.0.0",
    "sharp": "^0.34.5"
  }
}
